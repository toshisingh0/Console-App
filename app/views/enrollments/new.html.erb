<h1>Enroll Student in Course</h1>

<%= form_with model: @enrollment do |f| %>
  <div>
    <%= f.label :student_id, "Select Student" %><br>
    <%= f.collection_select :student_id, @students, :id, :name %>
  </div>

  <div>
    <%= f.label :course_id, "Select Course" %><br>
    <%= f.collection_select :course_id, @courses, :id, :title %>
  </div>

  <br>
  <%= f.submit "Enroll" %>
<% end %>

<br>
<%= link_to "Back", root_path %>
