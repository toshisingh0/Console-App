<h1>All Students</h1>

<table border="1" cellspacing="0" cellpadding="8">
  <thead>
    <tr>
      <th>Name</th>
      <th>Email</th>
    </tr>
  </thead>

  <tbody>
    <% @students.each do |student| %>
      <tr>
        <td><%= student.name %></td>
        <td><%= student.email %></td>
       
      </tr>
    <% end %>
  </tbody>
</table>

<br>
<%= link_to "Add New Student", new_student_path %>  |


<%= link_to "Back", root_path %>
